{
  "name": "@acvil-tiptap/react",
  "version": "0.1.0",
  "description": "Configurable React collaborative editor component built with Tiptap and Yjs.",
  "keywords": [
    "collaboration",
    "editor",
    "hocuspocus",
    "react",
    "rich-text",
    "tiptap",
    "yjs"
  ],
  "homepage": "https://github.com/zhenghui-su/acvil-tiptap-react#readme",
  "bugs": {
    "url": "https://github.com/zhenghui-su/acvil-tiptap-react/issues"
  },
  "license": "MIT",
  "author": "Zhenghui Su",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhenghui-su/acvil-tiptap-react.git"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "docs/API.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "example": "vp exec tsx examples/dev.ts",
    "example:minimal": "vp exec tsx examples/dev.ts minimal",
    "example:rich": "vp exec tsx examples/dev.ts rich",
    "example:server": "npx -y @hocuspocus/cli --port 1234 --sqlite",
    "test": "vp test",
    "check": "vp check",
    "release:check": "vp check && vp test && vp pack && vp exec pnpm pack --dry-run",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-collaboration": "^3.20.4",
    "@tiptap/extension-collaboration-caret": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/y-tiptap": "^3.0.2",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@hocuspocus/provider": "^3.4.4",
    "@testing-library/react": "^16.3.2",
    "@tiptap/extension-character-count": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
